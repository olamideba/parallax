# App
APP_ENV=development
LOG_LEVEL=DEBUG
API_V1_PREFIX=/api/v1
BACKEND_CORS_ORIGINS=["http://localhost:3000"]

# Database (Supabase Postgres)
DATABASE_URL=postgresql://user:password@host:5432/dbname
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Redis / Celery
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# REDIS_URL=redis://localhost:6379  # overrides REDIS_HOST/PORT when set

# Qwen / DashScope
DASHSCOPE_API_KEY=
QWEN_MODEL_GATEKEEPER=qwen-turbo
QWEN_MODEL_DEBATE=qwen-plus
QWEN_MODEL_ARBITRATOR=qwen-plus

# Debate settings
DEBATE_ROUND_CAP=3

# Cloudflare R2 (publication PDFs, CV attachments)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=parallax-files
R2_PUBLIC_BASE_URL=

# Email intake (Cloudflare Email Routing / Postmark Inbound webhook)
INTAKE_WEBHOOK_SECRET=
